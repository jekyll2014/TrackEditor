<Window x:Class="TrackEditor.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TrackEditor — User Guide" Height="760" Width="860"
        WindowStartupLocation="CenterOwner">
    <DockPanel>
        <Border DockPanel.Dock="Bottom" Background="#F5F5F7" BorderBrush="#DDD" BorderThickness="0,1,0,0"
                Padding="10,6">
            <Button Content="Close" Width="80" HorizontalAlignment="Right" IsCancel="True"/>
        </Border>
        <FlowDocumentScrollViewer x:Name="Viewer" VerticalScrollBarVisibility="Auto"
                                  IsToolBarVisible="False" Padding="0"/>
    </DockPanel>
</Window>
