<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="HelixToolkit.Wpf" Version="3.1.2" />
    <PackageReference Include="Mapsui.Nts" Version="4.1.9" />
    <PackageReference Include="Mapsui.Wpf" Version="4.1.9" />
    <PackageReference Include="Microsoft.Data.Sqlite" Version="10.0.10" />
    <PackageReference Include="ScottPlot.WPF" Version="5.0.47" />
    <PackageReference Include="SkiaSharp" Version="2.88.9" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\TrackEditor.Core\TrackEditor.Core.csproj" />
    <ProjectReference Include="..\TrackEditor.Core.Skia\TrackEditor.Core.Skia.csproj" />
  </ItemGroup>

  <!-- Embed the repo README so the in-app Help ▸ User Guide renders the same doc (single source). -->
  <ItemGroup>
    <EmbeddedResource Include="..\README.md" LogicalName="TrackEditor.UserGuide.md" />
  </ItemGroup>

</Project>
