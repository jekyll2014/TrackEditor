<Window x:Class="TrackEditor.Map3DWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:h="clr-namespace:HelixToolkit.Wpf;assembly=HelixToolkit.Wpf"
        Title="3D View" Height="760" Width="1080"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Opacity" Value="0.9"/>
        </Style>
    </Window.Resources>

    <Grid>
        <h:HelixViewport3D x:Name="Viewport"
                           ShowViewCube="False" ShowCoordinateSystem="False"
                           ZoomExtentsWhenLoaded="False" IsHeadLightEnabled="False"
                           Background="#DCE6F0">
            <h:HelixViewport3D.Camera>
                <PerspectiveCamera x:Name="Cam" FieldOfView="55"
                                   Position="0,-1000,600" LookDirection="0,1000,-400" UpDirection="0,0,1"/>
            </h:HelixViewport3D.Camera>

            <h:SunLight/>
            <ModelVisual3D x:Name="TerrainVisual"/>
        </h:HelixViewport3D>

        <!-- ===== compass ===== -->
        <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="12"
                Background="#C0FFFFFF" BorderBrush="#888" BorderThickness="1" CornerRadius="46"
                Width="92" Height="92">
            <Canvas Width="90" Height="90">
                <Ellipse Canvas.Left="5" Canvas.Top="5" Width="80" Height="80"
                         Stroke="#666" StrokeThickness="1" Fill="#F5FFFFFF"/>
                <TextBlock Text="N" Canvas.Left="41" Canvas.Top="6" FontWeight="Bold" FontSize="11" Foreground="#C62828"/>
                <TextBlock Text="S" Canvas.Left="41" Canvas.Top="66" FontSize="11" Foreground="#555"/>
                <TextBlock Text="W" Canvas.Left="8"  Canvas.Top="36" FontSize="11" Foreground="#555"/>
                <TextBlock Text="E" Canvas.Left="72" Canvas.Top="36" FontSize="11" Foreground="#555"/>
                <!-- Needle: rotates to show which way the camera is looking. -->
                <Path Fill="#C62828" Data="M 45,14 L 51,48 L 45,43 L 39,48 Z">
                    <Path.RenderTransform>
                        <RotateTransform x:Name="NeedleRotate" CenterX="45" CenterY="45"/>
                    </Path.RenderTransform>
                </Path>
                <Ellipse Canvas.Left="41" Canvas.Top="41" Width="8" Height="8" Fill="#333"/>
            </Canvas>
        </Border>

        <TextBlock x:Name="HeadingText" HorizontalAlignment="Right" VerticalAlignment="Top"
                   Margin="0,108,20,0" FontWeight="Bold" Foreground="#333" Text="—"/>

        <!-- ===== navigation cross + altitude ===== -->
        <Border HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="12"
                Background="#C0FFFFFF" BorderBrush="#888" BorderThickness="1" CornerRadius="6" Padding="6">
            <StackPanel Orientation="Horizontal">
                <!-- X / Y movement across the ground plane -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Row="0" Grid.Column="1" Style="{StaticResource NavBtn}" Content="▲"
                            Click="MoveForward_Click" ToolTip="Move forward (+Y)"/>
                    <Button Grid.Row="1" Grid.Column="0" Style="{StaticResource NavBtn}" Content="◀"
                            Click="MoveLeft_Click" ToolTip="Move left (−X)"/>
                    <Button Grid.Row="1" Grid.Column="1" Style="{StaticResource NavBtn}" Content="⌂"
                            Click="ResetView_Click" ToolTip="Reset view"/>
                    <Button Grid.Row="1" Grid.Column="2" Style="{StaticResource NavBtn}" Content="▶"
                            Click="MoveRight_Click" ToolTip="Move right (+X)"/>
                    <Button Grid.Row="2" Grid.Column="1" Style="{StaticResource NavBtn}" Content="▼"
                            Click="MoveBack_Click" ToolTip="Move back (−Y)"/>
                </Grid>

                <!-- Z movement -->
                <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                    <Button Style="{StaticResource NavBtn}" Content="⤒" Click="MoveUp_Click" ToolTip="Move up (+Z)"/>
                    <TextBlock Text="Z" HorizontalAlignment="Center" FontSize="10" Foreground="#555"/>
                    <Button Style="{StaticResource NavBtn}" Content="⤓" Click="MoveDown_Click" ToolTip="Move down (−Z)"/>
                </StackPanel>

                <!-- Rotate / tilt / zoom around the point being looked at -->
                <Grid Margin="12,0,0,0" VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Rotate" FontSize="10" Foreground="#555"
                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <Button Grid.Row="0" Grid.Column="1" Style="{StaticResource NavBtn}" Content="↺"
                            Click="RotateLeft_Click" ToolTip="Rotate view left (horizontal)"/>
                    <Button Grid.Row="0" Grid.Column="2" Style="{StaticResource NavBtn}" Content="↻"
                            Click="RotateRight_Click" ToolTip="Rotate view right (horizontal)"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Tilt" FontSize="10" Foreground="#555"
                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <Button Grid.Row="1" Grid.Column="1" Style="{StaticResource NavBtn}" Content="▲"
                            Click="TiltUp_Click" ToolTip="Tilt up — look from higher (vertical)"/>
                    <Button Grid.Row="1" Grid.Column="2" Style="{StaticResource NavBtn}" Content="▼"
                            Click="TiltDown_Click" ToolTip="Tilt down — look from nearer the ground (vertical)"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Zoom" FontSize="10" Foreground="#555"
                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <Button Grid.Row="2" Grid.Column="1" Style="{StaticResource NavBtn}" Content="+"
                            Click="ZoomIn_Click" ToolTip="Zoom in (mouse wheel up)"/>
                    <Button Grid.Row="2" Grid.Column="2" Style="{StaticResource NavBtn}" Content="−"
                            Click="ZoomOut_Click" ToolTip="Zoom out (mouse wheel down)"/>
                </Grid>

                <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Vertical exaggeration" FontSize="10" Foreground="#555"/>
                    <StackPanel Orientation="Horizontal">
                        <Slider x:Name="ExagSlider" Width="110" Minimum="1" Maximum="4" Value="1"
                                TickFrequency="0.5" IsSnapToTickEnabled="True"
                                ValueChanged="Exaggeration_Changed" VerticalAlignment="Center"/>
                        <TextBlock x:Name="ExagLabel" Text="1.0×" Width="34" Margin="4,0,0,0"
                                   VerticalAlignment="Center" FontSize="11"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ===== status / hints ===== -->
        <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="12"
                Background="#C0FFFFFF" BorderBrush="#888" BorderThickness="1" CornerRadius="4" Padding="8,5">
            <StackPanel>
                <TextBlock x:Name="StatusText" Text="Building terrain…" FontWeight="Bold"/>
                <TextBlock Text="Left-drag: pan   Right-drag: rotate / tilt   Wheel: zoom"
                           FontSize="11" Foreground="#555" Margin="0,3,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
