<Window x:Class="TrackEditor.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="620" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Elevation sources" FontWeight="Bold" Margin="0,0,0,8"/>

        <!-- SRTM -->
        <GroupBox Grid.Row="1" Margin="0,0,0,10">
            <GroupBox.Header>
                <CheckBox x:Name="ChkSrtm" Content="SRTM .hgt tiles (local, offline)"
                          Checked="Srtm_Toggled" Unchecked="Srtm_Toggled"/>
            </GroupBox.Header>
            <StackPanel x:Name="SrtmPanel" Margin="6">
                <TextBlock Text="Folder containing .hgt tiles (e.g. N54E025.hgt):" Margin="0,0,0,4"/>
                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="Browse…" Width="80" Margin="6,0,0,0"
                            Click="BrowseSrtm_Click"/>
                    <TextBox x:Name="TxtSrtmFolder" VerticalContentAlignment="Center"/>
                </DockPanel>
                <CheckBox x:Name="ChkSrtmAuto" Content="Download missing tiles automatically" Margin="0,8,0,0"
                          ToolTip="Fetches gzipped SRTM tiles from the elevation-tiles-prod open dataset into the folder above."/>
            </StackPanel>
        </GroupBox>

        <!-- Online -->
        <GroupBox Grid.Row="2" VerticalAlignment="Top">
            <GroupBox.Header>
                <CheckBox x:Name="ChkOnline" Content="Online elevation service (fallback for missing points)"
                          Checked="Online_Toggled" Unchecked="Online_Toggled"/>
            </GroupBox.Header>
            <StackPanel x:Name="OnlinePanel" Margin="6">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="Provider:" VerticalAlignment="Center" Width="120"/>
                    <ComboBox x:Name="CmbProvider" Width="180" SelectionChanged="Provider_Changed">
                        <ComboBoxItem Content="OpenTopoData"/>
                        <ComboBoxItem Content="Open-Elevation"/>
                    </ComboBox>
                </StackPanel>
                <StackPanel x:Name="DatasetRow" Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="OpenTopoData dataset:" VerticalAlignment="Center" Width="120"/>
                    <ComboBox x:Name="CmbDataset" Width="180" IsEditable="True"
                              ToolTip="Pick a public OpenTopoData dataset, or type a custom one (e.g. for a self-hosted server)."/>
                </StackPanel>
                <TextBlock TextWrapping="Wrap" Foreground="#666" FontSize="11"
                           Text="Requires network access. Public services are rate-limited (OpenTopoData: 100 points/request, ~1 request/second, 1000/day). Used only to fill points SRTM could not provide."/>
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="3" Header="Base map" Margin="0,10,0,0" VerticalAlignment="Top">
            <StackPanel Margin="6">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="Provider:" VerticalAlignment="Center" Width="120"/>
                    <ComboBox x:Name="CmbBaseMap" Width="220">
                        <ComboBoxItem Content="OpenStreetMap"/>
                        <ComboBoxItem Content="OpenTopoMap (topographic)"/>
                        <ComboBoxItem Content="CyclOSM"/>
                        <ComboBoxItem Content="Esri World Imagery (satellite)"/>
                        <ComboBoxItem Content="Carto Light"/>
                    </ComboBox>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Tile cache limit:" VerticalAlignment="Center" Width="120"/>
                    <TextBox x:Name="TxtCacheLimit" Width="70" VerticalContentAlignment="Center"/>
                    <TextBlock Text="MB per map  (0 = no limit)" VerticalAlignment="Center" Margin="6,0,0,0" Foreground="#666"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="4" Header="Waypoint labels (map &amp; profile)" Margin="0,10,0,0" VerticalAlignment="Top">
            <StackPanel Margin="6">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="Background:" VerticalAlignment="Center" Width="90"/>
                    <TextBox x:Name="TxtWpBack" Width="90" VerticalContentAlignment="Center" TextChanged="WpColor_Changed"/>
                    <Border BorderBrush="#888" BorderThickness="1" Margin="8,0,0,0" Width="34" Height="22">
                        <Rectangle x:Name="RectWpBack"/>
                    </Border>
                    <TextBlock Text="e.g. #6A1B9A" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="#666"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Text:" VerticalAlignment="Center" Width="90"/>
                    <TextBox x:Name="TxtWpText" Width="90" VerticalContentAlignment="Center" TextChanged="WpColor_Changed"/>
                    <Border BorderBrush="#888" BorderThickness="1" Margin="8,0,0,0" Width="34" Height="22">
                        <Rectangle x:Name="RectWpText"/>
                    </Border>
                    <Border x:Name="WpPreviewBorder" Margin="14,0,0,0" Padding="10,3" CornerRadius="3"
                            VerticalAlignment="Center">
                        <TextBlock x:Name="WpPreviewText" Text="Waypoint" FontWeight="Bold"/>
                    </Border>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" Width="80" IsDefault="True" Click="Ok_Click"/>
            <Button Content="Cancel" Width="80" Margin="8,0,0,0" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
