        <!-- Icon+label content style for toolbar controls. -->
        <Style x:Key="ToolIcon" TargetType="Path">
            <Setter Property="Fill" Value="#444"/>
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
        </Style>
    </Window.Resources>
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Open GPX/KML/KMZ…" Click="OpenFile_Click" InputGestureText="Ctrl+O"/>
                <MenuItem Header="Save _Active Track as GPX…" Click="SaveActive_Click"/>
                <MenuItem Header="_Save Active Track as GPX…" Click="SaveActive_Click" InputGestureText="Ctrl+S"/>
                <MenuItem Header="Save A_ll Tracks as GPX…" Click="SaveAll_Click"/>
                <Separator/>
                <MenuItem Header="_Export Map Image…" Click="ExportMap_Click"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo" Click="Undo_Click" InputGestureText="Ctrl+Z"/>
                <MenuItem Header="_Redo" Click="Redo_Click" InputGestureText="Ctrl+Y"/>
                <Separator/>
                <MenuItem Header="_Copy Points" Click="CopyPoints_Click" InputGestureText="Ctrl+C"/>
                <MenuItem Header="_Paste Points After Selected" Click="PastePoints_Click" InputGestureText="Ctrl+V"/>
                <MenuItem Header="_Delete Selected Points" Click="DeletePoints_Click" InputGestureText="Del"/>
            </MenuItem>
            <MenuItem Header="_Track">
                <MenuItem Header="_New Empty Track (draw mode)" Click="NewTrack_Click"/>
                <MenuItem Header="Delete _Last Point" Click="DeleteLast_Click"/>
                <Separator/>
                <MenuItem Header="_Split at Selected Point" Click="Split_Click"/>
                <MenuItem Header="_Crop to Selected Range" Click="Crop_Click"/>
                <MenuItem Header="_Delete Selected Range" Click="DeletePoints_Click"/>
                <MenuItem Header="Si_mplify…" Click="Simplify_Click"/>
                <Separator/>
                <MenuItem Header="_Reverse Track" Click="Reverse_Click"/>
                <MenuItem Header="Apply _Elevation to Track (SRTM / Online)" Click="ApplyElevation_Click"/>
                <Separator/>
                <MenuItem Header="_Zoom to Track" Click="ZoomToTrack_Click"/>
                <MenuItem Header="Remove Track from _List" Click="RemoveTrack_Click"/>
            </MenuItem>
            <MenuItem Header="_Mode">
                <MenuItem Header="_View" IsCheckable="True"
                          IsChecked="{Binding IsChecked, ElementName=ModeView, Mode=TwoWay}"/>
                <MenuItem Header="_Edit (draw / move / insert)" IsCheckable="True"
                          IsChecked="{Binding IsChecked, ElementName=ModeEdit, Mode=TwoWay}"/>
                <MenuItem Header="Meas_ure" IsCheckable="True"
                          IsChecked="{Binding IsChecked, ElementName=ModeMeasure, Mode=TwoWay}"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem x:Name="MenuFlags" Header="Show _Mileage Flags" IsCheckable="True" Click="FlagsToggle_Click"/>
                <MenuItem Header="Mileage Flag _Content">
                    <MenuItem x:Name="FlagContentDist" Header="_Distance" IsCheckable="True" IsChecked="True"
                              Tag="0" Click="FlagContentMenu_Click"/>
                    <MenuItem x:Name="FlagContentTime" Header="_Time" IsCheckable="True"
                              Tag="1" Click="FlagContentMenu_Click"/>
                    <MenuItem x:Name="FlagContentBoth" Header="Distance + t_ime" IsCheckable="True"
                              Tag="2" Click="FlagContentMenu_Click"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Altitude on Profile" IsCheckable="True"
                          IsChecked="{Binding IsChecked, ElementName=ChkAlt, Mode=TwoWay}"/>
                <MenuItem Header="_Speed on Profile" IsCheckable="True"
                          IsChecked="{Binding IsChecked, ElementName=ChkSpeed, Mode=TwoWay}"/>
            </MenuItem>
            <MenuItem Header="T_ools">
                <MenuItem Header="_Settings…" Click="Settings_Click"/>
            </MenuItem>
        </Menu>

        <!-- Toolbar = quick access only; every command here is also in the top menu. -->
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar Band="0" BandIndex="0">
                <Button Click="OpenFile_Click" ToolTip="Open GPX / KML / KMZ (Ctrl+O)">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IcoOpen}" Style="{StaticResource ToolIcon}"/>
                        <TextBlock Text="Open" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Click="SaveActive_Click" ToolTip="Save the active track as GPX (Ctrl+S)">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IcoSave}" Style="{StaticResource ToolIcon}"/>
                        <TextBlock Text="Save" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Click="NewTrack_Click" ToolTip="Create an empty track and switch to Edit mode">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IcoNewTrack}" Style="{StaticResource ToolIcon}"/>
                        <TextBlock Text="New track" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Separator/>
                <Button x:Name="BtnUndo" Click="Undo_Click" ToolTip="Ctrl+Z">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IcoUndo}" Style="{StaticResource ToolIcon}"/>
                        <TextBlock Text="Undo" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="BtnRedo" Click="Redo_Click" ToolTip="Ctrl+Y">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IcoRedo}" Style="{StaticResource ToolIcon}"/>
                        <TextBlock Text="Redo" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Separator/>
                <RadioButton x:Name="ModeView" IsChecked="True" GroupName="Mode" Checked="Mode_Checked"
                             ToolTip="Click a point to select it; Ctrl/Shift extend selection">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IcoView}" Style="{StaticResource ToolIcon}"/>
                        <TextBlock Text="View" VerticalAlignment="Center"/>
                    </StackPanel>
                </RadioButton>
                <RadioButton x:Name="ModeEdit" GroupName="Mode" Checked="Mode_Checked"
                             ToolTip="Draw &amp; edit: click adds a point at the end (when the last point is selected), drag a point to move it, double-click inserts after the selected point; right-click removes the last point">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IcoDraw}" Style="{StaticResource ToolIcon}"/>
                        <TextBlock Text="Edit" VerticalAlignment="Center"/>
                    </StackPanel>
                </RadioButton>
                <RadioButton x:Name="ModeMeasure" GroupName="Mode" Checked="Mode_Checked" Click="ModeMeasure_Click"
                             ToolTip="Click points on the map to measure a path; click this button again to reset">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IcoMeasure}" Style="{StaticResource ToolIcon}"/>
                        <TextBlock Text="Measure" VerticalAlignment="Center"/>
                    </StackPanel>
                </RadioButton>
                <Separator/>
                <Button Click="DeletePoints_Click" ToolTip="Delete selected points (Del)">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IcoDelete}" Style="{StaticResource ToolIcon}"/>
                        <TextBlock Text="Del pts" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Separator/>
                <CheckBox x:Name="AutoRouteCheck" Click="AutoRoute_Click" VerticalAlignment="Center"
                          ToolTip="Auto-route: new points follow real paths (BRouter) instead of a straight line">
                    <TextBlock Text="Auto-route" VerticalAlignment="Center"/>
                </CheckBox>
                <Separator/>
                <CheckBox x:Name="FlagsCheck" Click="FlagsToggle_Click" VerticalAlignment="Center"
                          ToolTip="Show mileage/time flags along the track">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IcoFlag}" Style="{StaticResource ToolIcon}"/>
                        <TextBlock Text="Flags" VerticalAlignment="Center"/>
                    </StackPanel>
                </CheckBox>
            </ToolBar>
        </ToolBarTray>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <DockPanel HorizontalAlignment="Stretch"/>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>
            <StatusBarItem><TextBlock x:Name="StatusMode" Text="Mode: View"/></StatusBarItem>
            <Separator/>
            <StatusBarItem><TextBlock x:Name="StatusCoords" Text=""/></StatusBarItem>
            <Separator/>
            <!-- Right-docked background-activity indicator; shown only while a background task runs. -->
            <StatusBarItem x:Name="StatusBusyItem" DockPanel.Dock="Right" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⏳ " VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusBusy" FontWeight="Bold" Foreground="#E67E22" VerticalAlignment="Center"/>
                </StackPanel>
            </StatusBarItem>
            <StatusBarItem><TextBlock x:Name="StatusInfo" Text="Open a GPX/KML/KMZ file to start"/></StatusBarItem>
        </StatusBar>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===== left panel ===== -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="120"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Tracks" FontWeight="Bold" Margin="6,6,6,2"/>
                <ListBox x:Name="TracksList" Grid.Row="1" Margin="6,0,6,4"
                         SelectionChanged="TracksList_SelectionChanged"
                         MouseDoubleClick="TracksList_MouseDoubleClick"
                         ToolTip="Double-click a track to fit it in the map; right-click for more">
                    <!-- Stretch the row content to the full list width so a right-click anywhere on the
                         row - including the empty space right of the name - hits the item's context menu. -->
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <!-- Background is required so the stretched (otherwise empty) area is hit-testable.
                                 The menu lives in the template so each row gets its own instance. -->
                            <StackPanel Orientation="Horizontal" Background="Transparent">
                                <StackPanel.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Rename…" Click="CtxRenameTrack_Click"/>
                                        <MenuItem Header="Track Information…" Click="CtxTrackInfo_Click"/>
                                        <Separator/>
                                        <MenuItem Header="Save Track as GPX…" Click="CtxSaveTrack_Click"/>
                                        <MenuItem Header="Reverse Track" Click="CtxReverse_Click"/>
                                        <MenuItem Header="Simplify…" Click="CtxSimplify_Click"/>
                                        <MenuItem Header="Re-evaluate Elevation (SRTM / Online)" Click="CtxReevalElevation_Click"/>
                                        <Separator/>
                                        <MenuItem Header="Zoom to Track" Click="CtxZoomTrack_Click"/>
                                        <MenuItem Header="Remove from List" Click="CtxRemoveTrack_Click"/>
                                    </ContextMenu>
                                </StackPanel.ContextMenu>
                                <CheckBox IsChecked="{Binding Visible, Mode=TwoWay}" Click="TrackVisible_Click" VerticalAlignment="Center"/>
                                <Rectangle Width="14" Height="14" Fill="{Binding Swatch}" Margin="4,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Title}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="6,0,6,4">
                    <TextBlock Text="Color:" VerticalAlignment="Center"/>
                    <ComboBox x:Name="ColorCombo" Width="90" Margin="4,0" SelectionChanged="ColorCombo_Changed"/>
                    <TextBlock Text="Width:" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    <Slider x:Name="WidthSlider" Width="90" Minimum="1" Maximum="10" Value="3" Margin="4,0"
                            VerticalAlignment="Center" ValueChanged="WidthSlider_Changed"/>
                    <TextBlock x:Name="WidthLabel" Text="3" VerticalAlignment="Center" Width="18"/>
                </StackPanel>

                <DataGrid x:Name="PointsGrid" Grid.Row="3" Margin="6,0,6,4"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionMode="Extended" SelectionUnit="FullRow"
                          EnableRowVirtualization="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          HeadersVisibility="Column"
                          SelectionChanged="PointsGrid_SelectionChanged"
                          MouseDoubleClick="PointsGrid_MouseDoubleClick"
                          PreviewMouseRightButtonDown="PointsGrid_PreviewMouseRightButtonDown">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Copy Points" Click="CopyPoints_Click" InputGestureText="Ctrl+C"/>
                            <MenuItem Header="Paste Points After Selected" Click="PastePoints_Click" InputGestureText="Ctrl+V"/>
                            <MenuItem Header="Delete Selected Points" Click="DeletePoints_Click" InputGestureText="Del"/>
                            <Separator/>
                            <MenuItem Header="Split at Selected Point" Click="Split_Click"/>
                            <MenuItem Header="Crop to Selected Range" Click="Crop_Click"/>
                            <Separator/>
                            <MenuItem Header="Set Waypoint Name…" Click="CtxSetWaypoint_Click"/>
                            <MenuItem Header="Remove Waypoint" Click="CtxRemoveWaypoint_Click"/>
                            <Separator/>
                            <MenuItem Header="Center Point in Map" Click="CtxCenterPoint_Click"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="40"/>
                        <DataGridTextColumn x:Name="ColWaypoint" Header="⚑ Waypoint" Binding="{Binding NameStr}" Width="Auto" MinWidth="70"/>
                        <DataGridTextColumn x:Name="ColLat" Header="Lat" Binding="{Binding LatStr}" Width="72"/>
                        <DataGridTextColumn x:Name="ColLon" Header="Lon" Binding="{Binding LonStr}" Width="72"/>
                        <DataGridTextColumn x:Name="ColEle" Header="Ele, m" Binding="{Binding EleStr}" Width="50"/>
                        <DataGridTextColumn x:Name="ColTime" Header="Time" Binding="{Binding TimeStr}" Width="62"/>
                        <DataGridTextColumn x:Name="ColDist" Header="Km" Binding="{Binding DistStr}" Width="50"/>
                    </DataGrid.Columns>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <!-- Highlight named waypoint rows so key points stand out in the list. -->
                                <DataTrigger Binding="{Binding IsWaypoint}" Value="True">
                                    <Setter Property="Background" Value="#FFF3E0"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                </DataGrid>

                <StackPanel Grid.Row="4" Margin="6,0,6,6">
                    <Expander Header="Statistics" IsExpanded="True">
                        <TextBlock x:Name="StatsText" FontFamily="Consolas" FontSize="12" Margin="4" Text="—"/>
                    </Expander>
                    <!-- Shown only while 2+ points are selected. -->
                    <Expander x:Name="SelStatsPanel" Header="Selection statistics" IsExpanded="True"
                              Margin="0,4,0,0" Visibility="Collapsed">
                        <TextBlock x:Name="SelStatsText" FontFamily="Consolas" FontSize="12" Margin="4"
                                   Text="Select 2+ points"/>
                    </Expander>
                    <!-- Shown only in Measure mode. -->
                    <Expander x:Name="MeasurePanel" Header="Measurement" IsExpanded="True"
                              Margin="0,4,0,0" Visibility="Collapsed">
                        <TextBlock x:Name="MeasureText" FontFamily="Consolas" FontSize="12" Margin="4"
                                   Text="Click points on the map to measure"/>
                    </Expander>
                </StackPanel>
            </Grid>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#DDD"/>

            <!-- ===== map + plots ===== -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition x:Name="PlotRow" Height="230"/>
                </Grid.RowDefinitions>

                <mapsui:MapControl x:Name="MapCtrl" Grid.Row="0"
                                   MouseMove="MapCtrl_MouseMove"
                                   MouseLeave="MapCtrl_MouseLeave"
                                   PreviewMouseLeftButtonDown="MapCtrl_PreviewMouseLeftButtonDown"
                                   PreviewMouseLeftButtonUp="MapCtrl_PreviewMouseLeftButtonUp"
                                   PreviewMouseRightButtonUp="MapCtrl_PreviewMouseRightButtonUp">
                    <mapsui:MapControl.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Fit All Tracks" Click="MapFitAll_Click"/>
                            <MenuItem Header="Zoom to Active Track" Click="ZoomToTrack_Click"/>
                            <Separator/>
                            <MenuItem Header="Mode">
                                <MenuItem Header="View" Click="MapModeView_Click"/>
                                <MenuItem Header="Edit (draw / move / insert)" Click="MapModeEdit_Click"/>
                                <MenuItem Header="Measure" Click="MapModeMeasure_Click"/>
                            </MenuItem>
                            <MenuItem Header="New Track" Click="NewTrack_Click"/>
                            <Separator/>
                            <MenuItem Header="Delete Selected Points" Click="DeletePoints_Click" InputGestureText="Del"/>
                            <MenuItem Header="Reset Measurement" Click="MapClearMeasure_Click"/>
                            <Separator/>
                            <MenuItem Header="Export Map Image…" Click="ExportMap_Click"/>
                        </ContextMenu>
                    </mapsui:MapControl.ContextMenu>
                </mapsui:MapControl>

                <Popup x:Name="HoverPopup" Placement="Relative" PlacementTarget="{Binding ElementName=MapCtrl}"
                       AllowsTransparency="True" IsHitTestVisible="False">
                    <Border Background="#F2FFFDE7" BorderBrush="#888" BorderThickness="1" CornerRadius="3" Padding="6,4">
                        <TextBlock x:Name="HoverText" FontSize="12"/>
                    </Border>
                </Popup>

                <GridSplitter Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#DDD"/>

                <DockPanel Grid.Row="2">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8,2,8,0">
                        <TextBlock Text="Profile:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <CheckBox x:Name="ChkAlt" Content="Altitude" IsChecked="True" VerticalAlignment="Center"
                                  Margin="0,0,12,0" Checked="PlotSeriesToggle" Unchecked="PlotSeriesToggle"/>
                        <CheckBox x:Name="ChkSpeed" Content="Speed" IsChecked="True" VerticalAlignment="Center"
                                  Checked="PlotSeriesToggle" Unchecked="PlotSeriesToggle"/>
                    </StackPanel>
                    <sp:WpfPlot x:Name="ProfilePlot" MouseLeftButtonDown="ProfilePlot_MouseLeftButtonDown"
                                MouseMove="ProfilePlot_MouseMove" MouseLeave="Plot_MouseLeave"/>
                </DockPanel>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
